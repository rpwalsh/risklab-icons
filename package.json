{
  "name": "@risklab/icons",
  "version": "1.0.0",
  "description": "Original, accessible, framework-neutral SVG icons for data-rich interfaces.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./element": { "types": "./dist/element.d.ts", "import": "./dist/element.js" },
    "./sprite.svg": "./sprite/risklab-icons.svg",
    "./icons/*": "./icons/*.svg"
  },
  "files": ["dist", "icons", "sprite", "README.md", "LICENSE", "NOTICE"],
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "lint": "node scripts/check-source.mjs",
    "typecheck": "tsc --noEmit",
    "build": "npm run generate && tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "node --test tests/*.test.mjs",
    "test:browser": "playwright test",
    "check": "npm run typecheck && npm run test",
    "prepack": "npm run generate && npm run check && tsc -p tsconfig.build.json",
    "test:consumer": "node scripts/test-consumer.mjs",
    "pack:check": "npm run test:consumer",
    "release:check": "npm run lint && npm run typecheck && npm test && npm run build && npm run test:browser && npm run pack:check",
    "validate": "npm run release:check"
  },
  "keywords": ["icons", "svg", "web-components", "typescript", "accessible", "risklab"],
  "license": "Apache-2.0",
  "author": "Ryan Walsh",
  "repository": { "type": "git", "url": "https://github.com/rpwalsh/risklab-icons.git" },
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "devDependencies": { "@playwright/test": "^1.55.0", "typescript": "^5.7.0" }
}
